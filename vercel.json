{
  "rewrites": [
    { "source": "/api/auth/:action", "destination": "/api/auth?action=:action" },
    { "source": "/api/alerts/:action", "destination": "/api/alerts?action=:action" },
    { "source": "/api/admin/:action", "destination": "/api/admin?action=:action" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/reminders/dispatch",
      "schedule": "0 10 * * *"
    }
  ]
}
